{
  "name": "diamond-track-atlas",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "data:sync": "tsx scripts/data/sync-diamond-league.ts",
    "data:normalize": "tsx scripts/data/normalize-results.ts",
    "data:validate": "tsx scripts/data/validate-results.ts",
    "data:meta": "tsx scripts/data/generate-data-meta.ts",
    "check": "npm run data:validate && npm run build"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.22.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.7"
